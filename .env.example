# Ecommerce API base URL (origin only, no /api). Required for API tests.
# Development: http://localhost:3000
API_BASE_URL=http://localhost:3000

# UI (browser) tests use this as baseURL. Defaults to API_BASE_URL if not set.
# UI_BASE_URL=http://localhost:3000

# Optional: fallback base URL
# BASE_URL=http://localhost:3000

# Auth is session-based (NextAuth). For authenticated tests, use Playwright
# storage state from a browser login, or a test-only token if your app supports it.
# API_TOKEN=  # optional, if your app accepts bearer token for API tests

# E2E test user for login flow. Do not commit real credentials.
# TEST_USER_EMAIL=Test@example.com
# TEST_USER_PASSWORD=test12345
# TEST_USER_DISPLAY_NAME=Test
