# Ecommerce API base URL (no trailing slash). Required for API tests.
API_BASE_URL=https://your-api.example.com

# Optional: fallback base URL key (used if API_BASE_URL is not set)
# BASE_URL=https://your-api.example.com

# Optional: bearer token for authenticated endpoints. Do not commit real tokens.
# API_TOKEN=your-nonprod-token
